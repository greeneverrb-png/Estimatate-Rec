<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Estimate Record</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 20px;
      background: #f5f5f5;
    }

    .container {
      max-width: 400px;
      margin: auto;
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    h2 {
      text-align: center;
    }

    input {
      width: 100%;
      padding: 10px;
      margin: 8px 0;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    button {
      width: 100%;
      padding: 12px;
      background: green;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background: darkgreen;
    }

    .show-btn {
      margin-top: 10px;
      background: #333;
    }
  </style>
</head>

<body>

<div class="container">
  <h2>Estimate Record</h2>

  <input type="number" id="cash" placeholder="Cash Amount">
  <input type="number" id="online" placeholder="Online Amount">
  <input type="date" id="date">

  <button onclick="addRecord()">ENTER</button>
  <button class="show-btn" onclick="showRecords()">SHOW RECORD</button>
</div>

<script>
  // ✅ Auto fill today's date
  window.onload = function () {
    const today = new Date();
    const formattedDate = today.toISOString().split('T')[0];
    document.getElementById("date").value = formattedDate;
  };

  function addRecord() {
    const cash = Number(document.getElementById("cash").value) || 0;
    const online = Number(document.getElementById("online").value) || 0;
    const date = document.getElementById("date").value;

    const total = cash + online;

    const record = {
      cash,
      online,
      total,
      date
    };

    let records = JSON.parse(localStorage.getItem("records")) || [];
    records.push(record);

    localStorage.setItem("records", JSON.stringify(records));

    alert("Record Saved!");

    // clear fields but keep today's date again
    document.getElementById("cash").value = "";
    document.getElementById("online").value = "";

    const today = new Date().toISOString().split('T')[0];
    document.getElementById("date").value = today;
  }

  function showRecords() {
    window.location.href = "record.html";
  }
</script>

</body>
</html>
